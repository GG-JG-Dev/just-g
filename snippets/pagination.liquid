{%- comment -%}
  Renders a set of links for paginated results. Must be used within paginate tags.

  Usage:
  {% paginate results by 2 %}
    {% render 'pagination', paginate: paginate, anchor: '#yourID' %}
  {% endpaginate %}

  Accepts:
  - paginate: {Object}
  - anchor: {String} (optional) This can be added so that on page reload it takes you to wherever you've placed your anchor tag.
{%- endcomment -%}
{%- assign window = 1 -%}
{%- assign current = paginate.current_page -%}
{%- assign total = paginate.pages -%}
{%- assign lower_bound = current | minus: window -%}
{%- assign upper_bound = current | plus: window -%}
{%- assign ellipsis_shown = false -%}

{%- if paginate.parts.size > 0 -%}
  <link rel="stylesheet" href="{{ 'pagination.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript>{{ 'pagination.css' | asset_url | stylesheet_tag }}</noscript>

  <div class="t4s-pagination-wrapper t4s-w-100">
    <nav class="t4s-pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
      <ul data-ntjax-wrap{{ ajax }} class="t4s-pagination__list list-unstyled" role="list">
        <li>
          {% if paginate.previous %}
            <a
              href="
                {{ paginate.previous.url -}}
                {{- anchor }}
              "
              class="t4s-pagination__item pagination__item--next pagination__item-arrow"
              aria-label="            {{- 'general.pagination.previous' | t -}}"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m15 18-6-6 6-6"/>
              </svg>
            </a>
          {% else %}
            <span
              class="t4s-pagination__item pagination__item--next pagination__item-arrow is-disabled"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="0.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m15 18-6-6 6-6"/>
              </svg>
            </span>
          {% endif %}
        </li>

        {% comment %}
          {%- for part in paginate.parts -%}
            <li>
              {%- if part.is_link -%}
                <a
                  href="{{ part.url }}{{ anchor }}"
                  class="t4s-pagination__item link"
                  aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
                >
                  {{- part.title -}}
                </a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span
                    class="t4s-pagination__item pagination__item--current"
                    aria-current="page"
                    aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
                  >
                    {{- part.title -}}
                  </span>
                {%- else -%}
                  <span class="t4s-pagination__item">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            </li>
          {%- endfor -%}
        {% endcomment %}

        {%- for part in paginate.parts -%}
          {%- assign page_num = part.title | plus: 0 -%}

          {%- if page_num == 1 or page_num == total or page_num >= lower_bound and page_num <= upper_bound -%}
            {%- assign ellipsis_shown = false -%}
            <li>
              {%- if part.is_link -%}
                <a
                  href="{{ part.url }}{{ anchor }}"
                  class="t4s-pagination__item link"
                  aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
                >
                {{- part.title -}}
                </a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span
                    class="t4s-pagination__item pagination__item--current"
                    aria-current="page"
                    aria-label="{{ 'general.pagination.page' | t: number: part.title }}"
                  >
                    {{- part.title -}}
                  </span>
                {%- else -%}
                  <span class="t4s-pagination__item">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            </li>
          {%- else -%}
            {%- unless ellipsis_shown -%}
              <li><span class="t4s-pagination__item t4s-pagination__ellipsis">…</span></li>
              {%- assign ellipsis_shown = true -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}

        <li>
          {% if paginate.next %}
            <a
              href="{{ paginate.next.url }}{{ anchor }}"
              class="t4s-pagination__item pagination__item--prev pagination__item-arrow"
              aria-label="{{ 'general.pagination.next' | t }}"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          {% else %}
            <span
              class="t4s-pagination__item pagination__item--prev pagination__item-arrow is-disabled"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="0.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </span>
          {% endif %}
        </li>
      </ul>
    </nav>
  </div>
{%- endif -%}
