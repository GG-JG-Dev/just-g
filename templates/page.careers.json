    "custom_liquid_aXU3XN": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div style=\"text-align: center; margin-top: 20px;\">\n  <p style=\"font-size: 14px; color: #000000; font-weight: bold; margin-bottom: 10px;\">\n    If you’re ready to take your career to the next level with a brand that values \n    creativity, <br>collaboration, and innovation, apply today!<br>\n    <span style=\"color: #2A2513;\">hr@justg.com.ph</span>\n  </p>\n\n\n\n\n\n\n<div style=\"text-align: center; margin-top: 20px;\">\n  <a id=\"applyButton\"\n     href=\"#\"\n     style=\"display: inline-block; padding: 10px 20px; border: 2px solid #000000; color: #000000; text-decoration: none; border-radius: 5px; font-weight: bold; background-color: transparent; transition: all 0.3s ease;\">\n    Apply Now\n  </a>\n</div>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function() {\n    let button = document.getElementById(\"applyButton\");\n    let email = \"hr@justg.com.ph\";\n    let subject = \"Application_[Position]_[Surname]\";\n    let body = \"Body: [Type Cover Letter in the email body]%0D%0A%0D%0A[Attach relevant documents (e.g. CV or Resumé, Portfolio, etc.)]%0D%0A%0D%0A\";\n\n    if (/Android|iPhone|iPad|iPod/i.test(navigator.userAgent)) {\n      // Mobile: Open default email app\n      button.href = `mailto:${email}?subject=${subject}&body=${body}`;\n    } else {\n      // Desktop: Open Gmail Compose directly\n      button.href = `https://mail.google.com/mail/?view=cm&fs=1&to=${email}&su=${subject}&body=${body}`;\n      button.target = \"_blank\"; // Open in new tab\n    }\n  });\n</script>",
        "layout": "t4s-container-wrap",
